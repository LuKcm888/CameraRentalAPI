# ── Server ──
server.port=8080

# ── PostgreSQL (start via: docker compose up -d) ──
spring.datasource.url=jdbc:postgresql://localhost:5434/camerarental_dev
spring.datasource.username=dev
spring.datasource.password=your-db-password
spring.datasource.driver-class-name=org.postgresql.Driver

# ── JPA / Hibernate ──
spring.jpa.hibernate.ddl-auto=create-drop
spring.jpa.show-sql=true
spring.jpa.properties.hibernate.format_sql=true
spring.jpa.properties.hibernate.dialect=org.hibernate.dialect.PostgreSQLDialect

# ── H2 Console disabled ──
spring.h2.console.enabled=false

# ── Redis ──
spring.data.redis.host=localhost
spring.data.redis.port=6379
app.rate-limiting.use-redis=true

# ── Logging ──
logging.level.org.springframework.security=DEBUG
logging.level.com.camerarental=DEBUG
logging.level.org.hibernate.SQL=DEBUG

# ── JWT ──
spring.app.jwtExpiration=3600000
spring.app.jwtSecret=your-jwt-secret-key-min-64-characters-long-for-hs512-signing

# ── CORS ──
security.auth.allowed-origins=http://localhost:3000,http://localhost:5173

# ── Swagger docs available locally ──
app.security.allow-docs=true
