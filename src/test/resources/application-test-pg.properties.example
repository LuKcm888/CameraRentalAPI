# ── Test Profile: PostgreSQL via Testcontainers ──
# Datasource is configured dynamically by AbstractPostgresIT via @DynamicPropertySource

# ── JPA / Hibernate ──
spring.jpa.hibernate.ddl-auto=create-drop
spring.jpa.show-sql=false

# ── H2 Console disabled in tests ──
spring.h2.console.enabled=false

# ── JWT (test values) ──
spring.app.jwtSecret=your-test-jwt-secret-key-min-64-characters-long-for-hs512-signing
spring.app.jwtExpiration=86400000

# ── Disable Redis/Redisson (no Redis server in test environment) ──
spring.autoconfigure.exclude=org.redisson.spring.starter.RedissonAutoConfigurationV4,\
  org.springframework.boot.data.redis.autoconfigure.DataRedisAutoConfiguration,\
  org.springframework.boot.data.redis.autoconfigure.DataRedisReactiveAutoConfiguration,\
  org.springframework.boot.data.redis.autoconfigure.DataRedisRepositoriesAutoConfiguration
spring.data.redis.repositories.enabled=false

# ── CORS (not relevant for MockMvc tests, but prevents startup failure) ──
security.auth.allowed-origins=http://localhost:3000
